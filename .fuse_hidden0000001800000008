/* ============================================================
   THE PRIMAL ORACLE — single-animal profile page
   Reads URL params, resolves a compute result, renders the page.
   Depends on window.ENGINE, window.ORACLE, window.CINEMA.
   ============================================================ */
(function () {
  "use strict";
  const $ = (s, r=document) => r.querySelector(s);

  /* ---------- resolve the animal from URL params ---------- */
  function resolve() {
    const p = new URLSearchParams(location.search);

    // 1) full date
    const d = p.get("d");
    if (d) { const c = ENGINE.compute(d); if (c) return c; }

    // 2) explicit sign + animal
    const sign = p.get("sign"), animal = p.get("animal");
    if (sign && animal && ORACLE.WEST[sign] && ORACLE.EAST[animal]) {
      return ENGINE.fromSignAnimal(sign, animal);
    }

    // 3) primal animal name
    if (animal && !sign) {
      const loc = ENGINE.locate(animal);
      if (loc) return ENGINE.fromSignAnimal(loc.sign, loc.animal);
    }

    return null;
  }

  /* ---------- toast ---------- */
  function pulse(title, sub) {
    const t = $("#toast"); if (!t) return;
    t.innerHTML = `<strong>${title}</strong><span>${sub}</span>`;
    t.classList.add("show");
    clearTimeout(t._h); t._h = setTimeout(() => t.classList.remove("show"), 2600);
  }

  /* ---------- escape for safe insertion ---------- */
  function esc(s) {
    return String(s).replace(/[&<>"']/g, m => ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;" }[m]));
  }

  /* ---------- render the profile ---------- */
  function render(c) {
    const r = ENGINE.reading(c);
    const mp = ENGINE.moonPhase();
    const elemPrefix = c.noElement ? "" : (c.element + " ");
    const eastSub = c.noElement ? "Year animal" : (c.element + " year animal");

    // meta + title
    const title = "The " + c.primal + ": a Primal Animal of " + c.sign + " and the " + c.animal;
    document.title = title;
    $("#pageTitle").textContent = title;
    const desc = "The " + c.primal + " is where " + c.sign + " meets the Year of the " + c.animal +
      ". Read its essence, five gates, keeper stones, tonight's Moon, and who it matches.";
    $("#pageDesc").setAttribute("content", desc);
    $("#ogTitle").setAttribute("content", "The " + c.primal);
    $("#ogDesc").setAttribute("content", desc);

    // hero halves
    $("#eastCn").textContent = c.cn;
    $("#eastName").textContent = c.animal;
    $("#eastSub").textContent = eastSub;
    $("#westGlyph").textContent = c.glyph;
    $("#westName").textContent = c.sign;
    $("#heroEyebrow").textContent = c.sign + " crossed with the " + c.animal;

    // name + essence
    $("#primalName").textContent = c.primal;
    $("#essence").textContent = r.essence;

    // gates
    const g = $("#gates"); g.innerHTML = "";
    r.gates.forEach((x, i) => {
      const a = document.createElement("article");
      a.className = "gate";
      a.style.animationDelay = (0.08 * i) + "s";
      a.innerHTML = `<h4>${esc(x.t)}</h4><p>${esc(x.b)}</p>`;
      g.appendChild(a);
    });

    // stones
    $("#stones").innerHTML = r.stones.map(s => `<li>${esc(s)}</li>`).join("");

    // moon
    $("#moonNow").innerHTML = `Tonight the Moon is a <strong>${esc(mp.name)}</strong> (${mp.age} days into its cycle). A good night to ${esc(mp.advice)}.`;

    // matches, from ORACLE.EAST[animal]
    const e = ORACLE.EAST[c.animal];
    const lines = [];
    if (e.trine && e.trine.length) {
      lines.push({ label: "Trine allies", body: "The " + e.trine.join(" and the ") + " (San He). The strongest natural bond." });
    }
    if (e.secret) lines.push({ label: "Secret friend", body: "The " + e.secret + " (Liu He). An easy, balancing fit." });
    if (e.clash) lines.push({ label: "A clash", body: "The " + e.clash + " (Liu Chong). Opposed energies, to be handled with care." });
    if (e.harm) lines.push({ label: "A quiet harm", body: "The " + e.harm + " (Liu Hai). Watch for slow corrosion." });
    $("#matchLines").innerHTML = lines.map(l =>
      `<li><span class="lab">${esc(l.label)}</span><span class="bod">${esc(l.body)}</span></li>`).join("");
    $("#matchLede").textContent = "Across the Chinese cycle, the " + c.animal +
      " keeps its allies, one secret friend, one clash, and one quiet harm. Here is where this animal stands.";

    // share line
    const shareElem = c.noElement ? "" : (c.element + " ");
    $("#shareLine").value = "My Primal Animal is the " + c.primal + " (" + c.sign + " and the " +
      shareElem + c.animal + "). Find yours at the Primal Oracle.";

    // reveal the profile
    $("#askDate").hidden = true;
    $("#profile").hidden = false;

    wireShare(c);
    wireReplay(c);
  }

  /* ---------- share + copy ---------- */
  function wireShare(c) {
    const text = () => $("#shareLine").value;
    $("#shareBtn").onclick = async () => {
      try {
        if (navigator.share) { await navigator.share({ title: "The Primal Oracle", text: text() }); }
        else { await navigator.clipboard.writeText(text()); pulse("Copied to clipboard", "share it with a friend"); }
      } catch (e) {}
    };
    $("#copyBtn").onclick = async () => {
      try { await navigator.clipboard.writeText(text()); pulse("Copied to clipboard", "send it to someone you wonder about"); }
      catch (e) {}
    };
    const cb = $("#cardBtn");
    if (cb) cb.onclick = async () => {
      if (!window.PCARD) return;
      cb.textContent = "Drawing your card"; cb.disabled = true;
      try { await PCARD.shareAnimal(c); pulse("Your card is ready", "save it or send it on"); } catch (e) {}
      cb.textContent = "Download my card"; cb.disabled = false;
    };
  }

  /* ---------- replay the cinematic reveal ---------- */
  function wireReplay(c) {
    const btn = $("#replayBtn");
    btn.onclick = () => { if (window.CINEMA) CINEMA.run(c, () => {}); };
  }

  /* ---------- date form fallback ---------- */
  function showForm() {
    $("#profile").hidden = true;
    $("#askDate").hidden = false;
    $("#dateForm").addEventListener("submit", (ev) => {
      ev.preventDefault();
      const v = $("#dateInput").value;
      if (!ENGINE.compute(v)) { $("#dateMsg").textContent = "Please enter a date of birth to open a profile."; return; }
      location.search = "?d=" + encodeURIComponent(v);
    });
  }

  /* ---------- starfield (simplified runStars) ---------- */
  function runStars() {
    const cv = $("#sky"); if (!cv) return;
    const ctx = cv.getContext("2d");
    function size() { cv.width = innerWidth; cv.height = Math.max(innerHeight, document.body.scrollHeight); }
    size(); addEventListener("resize", size);
    const N = Math.min(180, Math.floor(innerWidth / 8));
    const stars = Array.from({ length: N }, () => ({
      x: Math.random() * cv.width, y: Math.random() * cv.height,
      r: Math.random() * 1.4 + 0.2, a: Math.random(), s: Math.random() * 0.02 + 0.004
    }));
    (function frame() {
      ctx.clearRect(0, 0, cv.width, cv.height);
      for (const st of stars) {
        st.a += st.s; const al = 0.35 + Math.abs(Math.sin(st.a)) * 0.55;
        ctx.beginPath(); ctx.arc(st.x, st.y, st.r, 0, 7);
        ctx.fillStyle = `rgba(245,236,210,${al})`; ctx.fill();
      }
      requestAnimationFrame(frame);
    })();
  }

  /* ---------- init ---------- */
  function init() {
    const c = resolve();
    if (c) render(c); else showForm();
    runStars();
  }
  document.addEventListener("DOMContentLoaded", init);
})();
</script>
