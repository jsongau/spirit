<script>
(function () {
  "use strict";
  const O = ORACLE;
  const $ = (s) => document.querySelector(s);
  const LS_KEY = "primal_oracle_v1";

  /* ---------- starfield (matched to the rest of the site) ---------- */
  (function runStars(){
    const cv = $("#sky"); if (!cv) return;
    const ctx = cv.getContext("2d");
    function size(){ cv.width = innerWidth; cv.height = Math.max(innerHeight, document.body.scrollHeight); }
    size(); addEventListener("resize", size);
    const N = Math.min(160, Math.floor(innerWidth / 9));
    const stars = Array.from({length:N}, () => ({
      x: Math.random()*cv.width, y: Math.random()*cv.height,
      r: Math.random()*1.4 + 0.2, a: Math.random(), s: Math.random()*0.02 + 0.004
    }));
    (function frame(){
      ctx.clearRect(0,0,cv.width,cv.height);
      for (const st of stars){
        st.a += st.s; const al = 0.35 + Math.abs(Math.sin(st.a))*0.55;
        ctx.beginPath(); ctx.arc(st.x, st.y, st.r, 0, 7);
        ctx.fillStyle = `rgba(245,236,210,${al})`; ctx.fill();
      }
      requestAnimationFrame(frame);
    })();
  })();

  /* ---------- safe localStorage helpers ---------- */
  function readStore(){
    try { return JSON.parse(localStorage.getItem(LS_KEY)) || {}; }
    catch (e) { return {}; }
  }
  function writeBirth(dateStr){
    try {
      const obj = readStore();
      obj.birth = dateStr;
      localStorage.setItem(LS_KEY, JSON.stringify(obj));
    } catch (e) { /* storage may be unavailable; fail quietly */ }
  }

  /* ---------- one-line meanings, drawn from chamber 14 ----------
     Stones listed in the library carry the chamber's own wording.
     Stones the reading can return that are not in the library get a
     short, tasteful line written for this page. ---------- */
  const MEANING = {
    "Moonstone":"Captured moonlight; intuition, emotional balance, and new beginnings.",
    "Labradorite":"The aurora in stone; protection that keeps you receptive while it guards.",
    "Black Tourmaline":"The bouncer; blocks negativity and grounds fear from the outside in.",
    "Rose Quartz":"The heart's stone; unhurried self-love, compassion, and softened grief.",
    "Carnelian":"Warm blood-orange; creativity, courage, and restored drive.",
    "Citrine":"Bottled sunlight; wealth, optimism, and personal will.",
    "Tiger's Eye":"Courage with focus; grounded ambition and protection in action.",
    "Amethyst":"Sober clarity; calm, sleep, intuition, and breaking compulsions.",
    "Lapis Lazuli":"Royal blue; inner wisdom, honest speech, and meditation insight.",
    "Obsidian":"Volcanic glass; shadow work, cutting cords, and fierce protection.",
    "Turquoise":"The sky-stone; protection in travel, healing, and honest speech.",
    "Garnet":"Slow fire; devotion, vitality, and courage in love and work.",
    "Aquamarine":"Calm sea-water; courage to speak and clarity under emotion.",
    "Amazonite":"The peacekeeper; calm words and the balance of heart and speech.",
    "Hematite":"Iron weight; grounding, stability, and scattered energy pulled down.",
    "Smoky Quartz":"The gentle transmuter; grounds anxiety without walling you off.",
    "Green Jade":"The stone of heaven; serene fortune, harmony, and steady luck.",
    "Clear Quartz":"The master amplifier; raises the volume of any intention beside it.",
    "Pearl":"Born of the tide; gentleness, motherhood, and a soul steadied through change.",
    "Ammonite (fossil)":"A spiral shell turned to permanent stone; keeps energy and fortune flowing."
  };
  function meaningFor(name){
    return MEANING[name] || "A traditional ally for focus and intention; carry it for what you mean to keep.";
  }

  /* ---------- the library, lightly grouped, from chamber 14 ---------- */
  const LIBRARY = {
    masters: [
      ["Clear Quartz","The master amplifier; the blank page of the mineral world.","Amplifying any intention, clarifying the mind, and powering up other stones."],
      ["Selenite","Liquid light; the self-cleansing stone.","Clearing stagnant energy, mental clarity, and charging other crystals. Never wet."],
      ["Amethyst","Sober clarity; the spiritual quieter.","Calm, sleep, intuition, and breaking compulsions. Fades in sun."],
      ["Smoky Quartz","The gentle transmuter; grounding without armor.","Releasing heavy moods and turning negativity into something usable."],
      ["Fluorite","The mental tuning-fork; order from chaos.","Focus, study, and decluttering the mind. Can fade in sun."]
    ],
    love: [
      ["Rose Quartz","The heart's stone; unconditional, unhurried love.","Self-love, repairing trust, and opening to being loved. Fades in sun."],
      ["Green Aventurine","The quiet optimist; the luck of the heart.","Heart-centered prosperity, calming anger, and gentle good fortune."],
      ["Rhodonite","The wound-tender; love after injury.","Forgiveness, emotional recovery, and releasing resentment."],
      ["Garnet","Slow fire; devotion and vitality.","Passion, commitment, and courage in love and work."]
    ],
    protect: [
      ["Black Tourmaline","The bouncer; shields from the outside in.","Blocking negativity, grounding fear, and shielding from interference."],
      ["Obsidian","Volcanic glass; the unflinching mirror.","Shadow work, cutting cords, and fierce protection."],
      ["Hematite","Iron weight; the anchor.","Grounding, stability, and pulling scattered energy into the body."],
      ["Black Onyx","The composed sentinel; strength under strain.","Steadiness in grief or stress, willpower, and quiet defense."],
      ["Jasper","The supreme nurturer; the stone of endurance.","Sustaining you through stress, grounding, and steadiness over the long haul."]
    ],
    intuit: [
      ["Lapis Lazuli","Royal blue; the truth-teller.","Inner wisdom, intuition, honest speech, and meditation insight."],
      ["Sodalite","The level head; logic married to intuition.","Self-trust, clear thinking, and truthful expression."],
      ["Aquamarine","Calm sea-water; the soother of speech.","Courage to speak, calm under emotion, and clear communication."],
      ["Kyanite","The aligner; never needs cleansing.","Aligning all chakras, deep meditation, and calm communication."],
      ["Amazonite","The peacekeeper; the soothing teal.","Calming words and balancing heart and speech."]
    ],
    abund: [
      ["Citrine","Bottled sunlight; the merchant's stone.","Wealth, manifestation, and confidence in commerce. Fades in sun."],
      ["Pyrite","Fool's gold, real nerve; the manifesting metal.","Abundance, drive, and self-worth. Never wet, since it rusts."],
      ["Tiger's Eye","Courage with focus; the warrior's calm.","Confidence, decisiveness, and grounded ambition."],
      ["Jade","The stone of heaven; serene fortune.","Prosperity, harmony, and steady luck, prized for millennia in Chinese tradition."],
      ["Carnelian","Warm blood-orange; lit vitality.","Creativity, courage, motivation, and restored drive."]
    ]
  };

  const LUNAR = [
    ["Moonstone","Captured moonlight; the stone of new beginnings.",
     "Moonstone is feldspar with a soft inner glow called adularescence, light that floats inside the gem and rolls across its surface as you tilt it, exactly the way the Moon shines by borrowed light. It is worked with for intuition, emotional balance, cyclical change, and the divine feminine. Where another person might choose a birthstone, the lunar Snail simply belongs to this one. Carry it through a full cycle and it becomes a companion to the new-moon practice, a thing to hold while you tell one true thing to one chosen person."],
    ["Labradorite","The aurora in stone; the seer's shield.",
     "Labradorite is the storm-grey feldspar that erupts in peacock blue and gold when light hits it at the right angle. Inuit lore held that the northern lights were once trapped inside the rock until a hunter struck them free, and the stone still wears the leftover aurora. It is the tradition's premier stone of transformation and a protector of the open intuitive. Most protection stones wall you off; labradorite is said to let you stay porous and perceptive without being flooded, a shell that breathes. Pair it with moonstone for lunar intuition with a guard on the door."]
  ];

  function card(name, essence, use){
    const el = document.createElement("article");
    el.className = "libCard";
    el.innerHTML =
      '<h4>' + name + '</h4>' +
      '<p class="ess">' + essence + '</p>' +
      '<p class="use">' + use + '</p>';
    return el;
  }
  function fill(id, list){
    const wrap = $(id); if (!wrap) return;
    const frag = document.createDocumentFragment();
    list.forEach((row) => frag.appendChild(card(row[0], row[1], row[2])));
    wrap.appendChild(frag);
  }
  fill("#grpMasters", LIBRARY.masters);
  fill("#grpLove",    LIBRARY.love);
  fill("#grpProtect", LIBRARY.protect);
  fill("#grpIntuit",  LIBRARY.intuit);
  fill("#grpAbund",   LIBRARY.abund);

  (function fillLunar(){
    const wrap = $("#grpLunar");
    const frag = document.createDocumentFragment();
    LUNAR.forEach((row) => {
      const el = document.createElement("article");
      el.className = "lunarCard";
      el.innerHTML =
        '<div class="lunarGlow" aria-hidden="true"></div>' +
        '<h4>' + row[0] + '</h4>' +
        '<p class="ess">' + row[1] + '</p>' +
        '<p class="depth">' + row[2] + '</p>';
      frag.appendChild(el);
    });
    wrap.appendChild(frag);
  })();

  /* ---------- the keeper-stone finder ---------- */
  const form = $("#stoneForm");
  const input = $("#stoneDate");
  const msg = $("#stoneMsg");
  const result = $("#keeperResult");

  function render(dateStr){
    const c = ENGINE.compute(dateStr);
    if (!c){ msg.textContent = "That date did not read. Try another."; return false; }

    const r = ENGINE.reading(c);
    const stones = (r.stones || []).filter(Boolean);

    $("#keeperLine").innerHTML =
      'Your animal is the <b>' + c.primal + '</b>, ' + c.sign +
      ' crossed with the Year of the ' + c.animal + '. These are the stones the tradition keeps for you.';

    const chips = $("#chips");
    chips.innerHTML = "";
    stones.forEach((name) => {
      const chip = document.createElement("div");
      chip.className = "chip";
      chip.innerHTML =
        '<span class="chipName">' + name + '</span>' +
        '<span class="chipMean">' + meaningFor(name) + '</span>';
      chips.appendChild(chip);
    });

    const sun = O.SUN_STONE[c.sign];
    $("#sunStone").innerHTML =
      '<span class="sunLabel">Your Sun-sign birthstone</span>' +
      '<span class="sunName">' + sun + '</span>' +
      '<span class="sunMean">' + meaningFor(sun) + '</span>';

    result.hidden = false;
    msg.textContent = "";
    return true;
  }

  form.addEventListener("submit", function(e){
    e.preventDefault();
    const v = input.value;
    if (!v){ msg.textContent = "Enter your date of birth first."; return; }
    if (render(v)) writeBirth(v);
  });

  /* ---------- prefill on return ---------- */
  (function prefill(){
    const obj = readStore();
    if (obj && typeof obj.birth === "string" && obj.birth){
      input.value = obj.birth;
      render(obj.birth);
    }
  })();
})();
</script>
