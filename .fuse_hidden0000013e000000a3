<script>
(function () {
  "use strict";
  const $ = (s, r = document) => r.querySelector(s);

  /* ---------- STARFIELD ---------- */
  (function runStars(){
    const cv = $("#sky"); if (!cv) return; const ctx = cv.getContext("2d");
    function size(){ cv.width = innerWidth; cv.height = Math.max(innerHeight, document.body.scrollHeight); }
    size(); addEventListener("resize", size);
    const N = Math.min(180, Math.floor(innerWidth / 8));
    const stars = Array.from({length:N}, () => ({
      x: Math.random()*cv.width, y: Math.random()*cv.height,
      r: Math.random()*1.4+0.3, a: Math.random()*6.28, s: Math.random()*0.02+0.004
    }));
    (function frame(){ ctx.clearRect(0,0,cv.width,cv.height);
      for (const st of stars){ st.a += st.s; const al = 0.35 + Math.abs(Math.sin(st.a))*0.55;
        ctx.beginPath(); ctx.arc(st.x, st.y, st.r, 0, 7); ctx.fillStyle = `rgba(245,236,210,${al})`; ctx.fill(); }
      requestAnimationFrame(frame); })();
  })();

  /* ---------- TIER GUIDANCE (one short paragraph per tier) ---------- */
  const GUIDANCE = {
    "Twin Flame": "You recognize each other early, and the recognition holds. A bond this easy tempts you to stop tending it, certain it will hold itself, and it will not. Keep choosing each other on the ordinary days. The wheel opened the door. Walking through it is still your work.",
    "Strong": "The bones are good. You move at compatible speeds and your instincts mostly agree, so your quarrels are about the world rather than about each other. Trust that ground enough to be plainly honest inside it, because a strong match grows dull under politeness and deepens under truth told kindly.",
    "Workable": "There is real ground here and a few honest gaps, and nothing carries you automatically. That is its own gift. Name where your rhythms differ and build small agreements around them. Pairs who learn to do on purpose what the easy matches were handed for free tend to outlast them.",
    "Friction": "You pull in different directions, and tension is not the same as doom. Friction can make heat or it can make wear, and the difference is whether you treat the gap as a contest to win or a difference to respect. Slow down where you grind, get specific about what each of you needs, and let the contrast sharpen you both.",
    "Karmic Lesson": "This is the hard, instructive kind of bond, the one that keeps handing each of you the lesson you came to learn, usually through the other person. It can wound and it can free. Go in with clear eyes, firm boundaries, and the humility to grow. Held well it changes you. Held badly it repeats."
  };

  /* ---------- HELPERS ---------- */
  function fmtDate(d){
    return d.toLocaleDateString(undefined, { year:"numeric", month:"long", day:"numeric" });
  }
  function animalBlock(c, label){
    return `<div class="mAnimal">
      <small class="mLabel">${label}</small>
      <div class="mGlyphRow"><span class="mGlyph">${c.glyph}</span><span class="mCn">${c.cn}</span></div>
      <div class="mPrimal">${c.primal}</div>
      <div class="mMeta">${c.sign} &middot; ${c.animal}</div>
    </div>`;
  }

  /* ---------- MATCH ---------- */
  const form = $("#matchForm");
  const out = $("#matchResult");
  const msg = $("#matchMsg");

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    msg.textContent = "";
    const dateA = $("#mDateA").value, dateB = $("#mDateB").value;
    if (!dateA || !dateB){ msg.textContent = "Enter both dates of birth to test the match."; return; }

    const a = ENGINE.compute(dateA), b = ENGINE.compute(dateB);
    if (!a || !b){ msg.textContent = "One of those dates did not read. Check and try again."; return; }
    const m = ENGINE.compatibility(a, b);

    const tierClass = "tier-" + m.tier.replace(/\s/g, "");
    const notes = m.notes.map(n => `<li>${n}</li>`).join("");
    const guidance = GUIDANCE[m.tier] || "";
    const shareLine = `Our Primal match is ${m.tier}: the ${a.primal} and the ${b.primal}, scoring ${m.score} of 18. Test yours at The Primal Oracle.`;

    out.innerHTML = `
      <div class="matchCard">
        <div class="matchHead">
          ${animalBlock(a, "You")}
          <span class="amp">&amp;</span>
          ${animalBlock(b, "Them")}
        </div>

        <span class="tierBadge bigTier ${tierClass}">${m.tier}</span>

        <div class="scoreRow">
          <span class="scoreNum">${m.score}</span>
          <span class="scoreOf">of 18</span>
        </div>
        <div class="scoreTrack"><i style="width:${Math.max(0, Math.min(100, Math.round(m.score / 18 * 100)))}%"></i></div>

        <h3 class="mSub">What the wheel weighed</h3>
        <ul class="matchNotes">${notes}</ul>

        <h3 class="mSub">Guidance for this bond</h3>
        <p class="guidance">${guidance}</p>
        <p class="guidance honest">Compatibility supports a bond. It does not make one. What you build from here is yours.</p>

        <h3 class="mSub">Share this match</h3>
        <p class="dim mDates">${fmtDate(a.date)} and ${fmtDate(b.date)}</p>
        <div class="shareBox">
          <input id="shareLine" readonly aria-label="Share text" value="${shareLine.replace(/"/g, "&quot;")}">
          <button class="btn" id="shareBtn" type="button">Share this match</button>
          <button class="btn ghost" id="cardBtn" type="button">Download match card</button>
          <button class="btn ghost" id="copyBtn" type="button">Copy</button>
        </div>
        <p class="msg" id="shareMsg" style="color:var(--brass-bright)"></p>
      </div>`;

    out.classList.add("show");
    out.scrollIntoView({ behavior:"smooth", block:"start" });

    const shareMsg = $("#shareMsg");
    $("#shareBtn").addEventListener("click", async () => {
      if (navigator.share){
        try { await navigator.share({ title:"The Primal Oracle", text: shareLine, url: location.href }); }
        catch (err) { /* user dismissed */ }
      } else {
        copyShare();
      }
    });
    $("#copyBtn").addEventListener("click", copyShare);
    const cb = $("#cardBtn");
    if (cb) cb.addEventListener("click", async () => {
      if (!window.PCARD) return;
      cb.textContent = "Drawing your card"; cb.disabled = true;
      try { await PCARD.shareMatch(a, b, m); shareMsg.textContent = "Your match card is ready."; } catch (e) {}
      cb.textContent = "Download match card"; cb.disabled = false;
    });
    async function copyShare(){
      try { await navigator.clipboard.writeText(shareLine); shareMsg.textContent = "Copied. Send it to them."; }
      catch (err) { const el = $("#shareLine"); el.select(); document.execCommand && document.execCommand("copy"); shareMsg.textContent = "Copied. Send it to them."; }
    }
  });
})();
</script>
