/* ============================================================
   THE PRIMAL ORACLE — nav core (the sticky bar)
   Dropdown mega-nav shell. Uses oracle.css tokens.
   ============================================================ */

.pn-bar{position:sticky; top:0; z-index:120; backdrop-filter:blur(10px);
  background:var(--nav-bg);
  border-bottom:1px solid var(--line,#2a2c44)}
.pn-inner{max-width:1140px; margin:0 auto; padding:16px 26px; display:flex; align-items:center; gap:26px}

.pn-brand{font-family:var(--serif,serif); font-size:1.35rem; letter-spacing:.5px; color:var(--moon,#f5ecd2); white-space:nowrap; text-decoration:none}
.pn-brand b{color:var(--brass,#d6c18c)}

/* top-level nav */
.pn-nav{display:flex; align-items:center; gap:8px; margin-left:8px}
.pn-link,.pn-trigger{font:500 .92rem/1 var(--sans,sans-serif); color:var(--muted,#9a9bb0);
  padding:11px 15px; border-radius:10px; letter-spacing:.01em; white-space:nowrap;
  background:transparent; border:none; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:8px;
  transition:color .18s, background .18s}
.pn-link:hover,.pn-trigger:hover{color:var(--moon,#f5ecd2); background:rgba(214,193,140,.08)}
.pn-link.active,.pn-trigger.active{color:var(--brass-bright,#efe2b4)}
.pn-trigger .chev{width:7px; height:7px; border-right:1.5px solid currentColor; border-bottom:1.5px solid currentColor;
  transform:rotate(45deg) translateY(-1px); transition:transform .22s ease; opacity:.75}
.pn-trigger.expanded{color:var(--moon,#f5ecd2); background:rgba(214,193,140,.1)}
.pn-trigger.expanded .chev{transform:rotate(-135deg) translateY(1px)}
.pn-item{position:relative}

/* right-side tools */
.pn-tools{display:flex; align-items:center; gap:12px; margin-left:auto}
.pn-chip{display:inline-flex; align-items:center; gap:8px; padding:8px 13px; border-radius:999px;
  border:1px solid var(--line,#2a2c44); background:rgba(21,23,40,.6); color:var(--ivory,#ece7d8);
  font:500 .82rem/1 var(--sans,sans-serif); text-decoration:none; white-space:nowrap; transition:border-color .18s, color .18s}
.pn-chip:hover{border-color:var(--brass,#d6c18c); color:var(--moon,#f5ecd2)}
.pn-chip .v{color:var(--brass-bright,#efe2b4)}

.pn-burger{display:none; margin-left:6px; background:transparent; border:1px solid var(--line,#2a2c44);
  color:var(--moon,#f5ecd2); border-radius:11px; width:44px; height:40px; cursor:pointer; font-size:1.15rem}

body.pn-has-bar{scroll-padding-top:82px}

/* responsive: fold nav + tools into the drawer as space tightens */
@media(max-width:1040px){ .pn-chip .lbl{display:none} .pn-chip{padding:8px 10px} }
@media(max-width:900px){
  .pn-nav{display:none}
  .pn-burger{display:block}
}
@media(max-width:560px){
  .pn-tools{display:none}
  .pn-inner{padding:14px 18px; gap:14px}
}
